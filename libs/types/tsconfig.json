{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@prisma/client": ["../../apps/car-api/generated/prisma/client.ts"],
      "@prisma-generated/*": ["../../apps/car-api/generated/*"],
      "@car/common": ["../common/src/index.ts"],    
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
