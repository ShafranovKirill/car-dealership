generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id        String     @id @default(uuid())
  name      String     @unique
  images      Json?
  carModels CarModel[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model CarModel {
  id          String   @id @default(uuid()) // ID модели (UUID)
  name        String                        // Название модели (например, "Camry")
  generation  String?                        // Поколение (например, "XV70")
  yearFrom    Int?      @map("year_from")    // Год начала производства
  yearTo      Int?     @map("year_to")      // Год окончания производства (null, если еще выпускается)
  bodyType    BodyType? @map("body_type")    // Тип кузова (седан, хэтчбек и т.д.)
  carClass    CarClass? @map("car_class")    // Класс автомобиля (A, B, C, D, E и т.д.)
  images      Json?                         // Ссылки на картинки (в формате JSON)
  
  minPrice    Int?      @map("min_price")    // Минимальная цена автомобиля

  brandId String @map("brand_id")           // ID бренда (внешний ключ)
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade) // Связь с моделью бренда

  technicalInfo CarTechnicalInfo?           // Технические характеристики автомобиля
  
  configuration Configuration?              // Комплектация автомобиля

  createdAt DateTime @default(now()) @map("created_at") // Дата добавления записи в базу
  updatedAt DateTime @updatedAt @map("updated_at")        // Дата последнего обновления записи

  @@map("car_models") // Имя таблицы в БД
}

model CarTechnicalInfo {
  id String @id @default(uuid())             // ID тех. инфо (UUID)

  length    Int                             // Длина (в мм)
  width     Int                             // Ширина (в мм)
  height    Int                             // Высота (в мм)
  wheelbase Int                             // Колесная база (в мм)
  clearance Int                             // Дорожный просвет / клиренс (в мм)

  trunkVolume    Int  @map("trunk_volume")     // Объем багажника (в литрах)
  trunkMaxVolume Int? @map("trunk_max_volume") // Максимальный объем багажника (при сложенных сиденьях)

  engineType     EngineType       @map("engine_type")     // Тип двигателя (бензин, дизель, гибрид, электро)
  engineVolume   Float            @map("engine_volume")   // Объем двигателя (в литрах, например: 2.0)
  enginePower    Int              @map("engine_power")    // Мощность двигателя (в л.с.)
  engineTorque   Int              @map("engine_torque")   // Крутящий момент (в Нм)
  cylindersCount Int?             @map("cylinders_count") // Количество цилиндров (null для электромобилей)
  transmission   TransmissionType                         // Тип коробки передач (автомат, механика, робот)
  driveType      DriveType        @map("drive_type")      // Тип привода (передний, задний, полный)

  engineId String @map("engine_id")           // ID двигателя/маркировка мотора

  carModelId String   @unique @map("car_model_id") // ID автомобиля, к которому относятся характеристики
  carModel   CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade) // Связь с таблицей моделей

  @@map("car_technical_info") // Имя таблицы в БД
}
model Configuration {
  id          String @id @default(uuid())
  name        String 
  price       Int 
  description String
  images      Json


  carModelId String   @unique @map("car_model_id")
  carModel   CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("configurations")
}

model Staff {
  id           String  @id @default(uuid())
  login        String  @unique
  passwordHash String  @map("password_hash")
  name         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("staffs")
}

model MediaFile {
  id           String @id @default(uuid())
  bucket       String
  key          String
  originalName String @map("original_name")
  mimeType     String @map("mime_type")
  size         Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([mimeType])
  @@map("media_files")
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  WAGON
  COUPE
  MINIVAN
  PICKUP
}

enum CarClass {
  A
  B
  C
  D
  E
  F
  J
  M
  S
}

enum EngineType {
  BENZIN
  DIESEL
  HYBRID
  ELECTRIC
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  ROBOT
  VARIATOR
}

enum DriveType {
  FWD
  RWD
  AWD
}