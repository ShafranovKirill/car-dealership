generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model Brand {
  id        String     @id @default(uuid())
  name      String     @unique // Название марки (например, BMW, Audi)
  logo      String     // Ссылка на фото/логотип марки
  
  carModels CarModel[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("brands")
}

model CarModel {
  id             String           @id @default(uuid())
  modelName      String           // Модель (например, X5)
  generation     String           // Поколение (например, G05)
  yearFrom       Int              // Год начала производства поколения
  yearTo         Int?             // Год окончания (null, если выпускается сейчас)
  bodyType       BodyType
  carClass       CarClass
  images         Json             
  
  transmission   TransmissionType 
  drive          DriveType        

  brandId        String
  brand          Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)

  engineId       String
  engine         Engine           @relation(fields: [engineId], references: [id], onDelete: Restrict)
  
  dimensions     Dimensions?      
  configurations Configuration[]  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("car_models")
}

model Dimensions {
  id             String   @id @default(uuid())
  length         Int      // Длина в мм
  width          Int      // Ширина в мм
  height         Int      // Высота в мм
  wheelbase      Int      // Колесная база в мм
  clearance      Int      // Клиренс (дорожный просвет) в мм
  trunkVolume    Int      // Объем багажника в литрах (минимальный)
  trunkMaxVolume Int?     // Объем багажника при сложенных сиденьях (опционально)

  carModelId     String   @unique
  carModel       CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)

  @@map("dimensions")
}

model Engine {
  id             String          @id @default(uuid())
  name           String          // Код/название двигателя (например, EA888, B58)
  type           EngineType      // Тип топлива / питания
  volume         Float           // Объем в литрах (например, 2.0). Для электро можно ставить 0
  power          Int             // Мощность в л.с.
  torque         Int             // Крутящий момент в Нм
  cylinderCount  Int?            // Количество цилиндров (опционально для электро)

  carModels      CarModel[]      // Теперь один двигатель может стоять на разных моделях машин

  @@map("engines")
}

model Configuration {
  id             String           @id @default(uuid())
  name           String           // Название комплектации (например, "Comfort", "M Sport")
  price          Int              // Цена в копейках или целых единицах валюты

  carModelId     String
  carModel       CarModel         @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  
  customFeatures ConfigurationCustomFeature[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("configurations")
}

model FeatureCategory {
  id        String   @id @default(uuid())
  name      String   @unique // Название категории
  order     Int      @default(0) 

  featureKeys CustomFeatureKey[]

  @@map("feature_categories")
}

model CustomFeatureKey {
  id                String   @id @default(uuid())
  name              String   @unique // Название характеристики (например, "Климат-контроль")
  
  categoryId        String
  category          FeatureCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  configurations    ConfigurationCustomFeature[]

  @@map("custom_feature_keys")
}

model ConfigurationCustomFeature {
  id              String           @id @default(uuid())
  
  configurationId String
  configuration   Configuration    @relation(fields: [configurationId], references: [id], onDelete: Cascade)

  featureKeyId    String
  featureKey      CustomFeatureKey @relation(fields: [featureKeyId], references: [id], onDelete: Cascade)

  value           String          

  @@unique([configurationId, featureKeyId]) 
  @@map("configuration_custom_features")
}

model Staff {
  id           String  @id @default(uuid())
  login        String  @unique
  passwordHash String  @map("password_hash")
  name         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("staffs")
}

model MediaFile {
  id           String @id @default(uuid())
  bucket       String
  key          String
  originalName String @map("original_name")
  mimeType     String @map("mime_type")
  size         Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([mimeType])
  @@map("media_files")
}

enum BodyType {
  SEDAN       // Седан
  HATCHBACK   // Хэтчбек
  SUV         // Внедорожник / Кроссовер
  WAGON       // Универсал
  COUPE       // Купе
  MINIVAN     // Минивэн
  PICKUP      // Пикап
}

enum CarClass {
  A // Особо малый (Smart Fortwo)
  B // Малый (VW Polo, Kia Rio)
  C // Малый средний (Toyota Corolla, VW Golf)
  D // Средний (BMW 3, Passat)
  E // Бизнес-класс (Audi A6, Mercedes E-class)
  F // Представительский (BMW 7, Maybach)
  J // Внедорожники и кроссоверы
  M // Минивэны
  S // Спортивные купе / суперкары
}

enum EngineType {
  BENZIN    // Бензиновый
  DIESEL    // Дизельный
  HYBRID    // Гибрид
  ELECTRIC  // Электромотор
}

enum TransmissionType {
  MANUAL       // Механическая (МКПП)
  AUTOMATIC    // Автоматическая (АКПП)
  ROBOT        // Роботизированная (РКПП)
  VARIATOR     // Вариатор (CVT)
}

enum DriveType {
  FWD // Передний привод
  RWD // Задний привод
  AWD // Полный привод
}